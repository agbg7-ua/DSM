@model IEnumerable<WebMarkerSpace.Models.MaterialViewModel>

<table class="table" id="tabla-materiales">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Categoria)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Descripcion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Estado)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr data-material-id="@item.Id">
            <td>
                @Html.DisplayFor(modelItem => item.Nombre)
            </td>
            <td>
                @Localizer.Localize(item.Categoria)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Descripcion)
            </td>
            <td>
                @Localizer.Localize(item.Estado)
                @if (item.Estado == ApplicationCore.Domain.Enums.EstadoMaterial.Prestado && !string.IsNullOrEmpty(item.NombreUsuarioAsignado))
                {
                    <br /><small class="text-muted">@Localizer["Material.Index.LoanedTo", item.NombreUsuarioAsignado]</small>
                }
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">@Localizer["Common.Details"]</a>
                @if (User.IsInRole("Administrador"))
                {
                    <text> | </text>
                    <a asp-action="Edit" asp-route-id="@item.Id">@Localizer["Common.Edit"]</a>
                    <text> | </text>
                    <a asp-action="Delete" asp-route-id="@item.Id"
                       class="js-borrar-material" data-id="@item.Id" data-nombre="@item.Nombre">@Localizer["Common.DeleteLink"]</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted" id="materiales-sin-resultados">@Localizer["Material.Index.Empty"]</p>
}
