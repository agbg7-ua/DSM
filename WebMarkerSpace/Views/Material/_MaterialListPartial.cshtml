@model IEnumerable<WebMarkerSpace.Models.MaterialViewModel>
@using ApplicationCore.Domain.Enums

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-search" style="font-size:2.5rem;"></i>
        <p class="fs-5 mt-2">@Localizer["Material.Index.Empty"]</p>
        <a asp-action="Index" class="btn btn-outline-secondary mt-1">@Localizer["VerTodos"]</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4" id="grid-materiales">
        @foreach (var item in Model)
        {
            <div class="col" data-material-id="@item.Id" data-details-url="@Url.Action("Details", "Material", new { id = item.Id })">
                <div class="card h-100" style="cursor:pointer;">
                    <div style="height:180px; overflow:hidden; background:#f8f9fa; border-radius:0.375rem 0.375rem 0 0;"
                         class="d-flex align-items-center justify-content-center p-2">
                        @if (!string.IsNullOrEmpty(item.Imagen))
                        {
                            <img src="@item.Imagen" alt="@item.Nombre"
                                 style="max-width:100%; max-height:100%; object-fit:contain;" />
                        }
                        else
                        {
                            <div class="text-center text-muted">
                                <i class="bi bi-image" style="font-size:2rem;"></i>
                                <p class="small mt-1 mb-0">@Localizer["Material.Details.NoImage"]</p>
                            </div>
                        }
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@item.Nombre</h5>
                        <p class="card-text text-muted small mb-3">@item.Descripcion</p>
                        <div class="d-flex gap-2 flex-wrap">
                            <span class="badge bg-secondary">@Localizer.Localize(item.Categoria)</span>
                            @{
                                string badgeClass = item.Estado switch {
                                    EstadoMaterial.Disponible      => "bg-success",
                                    EstadoMaterial.Prestado        => "bg-primary",
                                    EstadoMaterial.EnMantenimiento => "bg-warning text-dark",
                                    EstadoMaterial.Roto            => "bg-danger",
                                    _                              => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeClass">@Localizer.Localize(item.Estado)</span>
                        </div>
                        @if (item.Estado == EstadoMaterial.Prestado && !string.IsNullOrEmpty(item.NombreUsuarioAsignado))
                        {
                            <p class="small text-muted mt-1 mb-0">
                                @Localizer.Localize(item.Estado) @string.Format(Localizer["Material.Index.LoanedTo"], item.NombreUsuarioAsignado)
                            </p>
                        }
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2 flex-wrap" style="position:relative; z-index:2;">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary stretched-link">
                            <i class="bi bi-eye me-1"></i>@Localizer["Common.Details"]
                        </a>
                        @if (User.IsInRole("Administrador"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil me-1"></i>@Localizer["Common.Edit"]
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger js-borrar-material"
                               data-id="@item.Id" data-nombre="@item.Nombre">
                                <i class="bi bi-trash me-1"></i>@Localizer["Common.DeleteLink"]
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
