@model IEnumerable<WebMarkerSpace.Models.MaterialViewModel>

@{
    ViewData["Title"] = "Materiales";
}

<h1>Materiales</h1>

@if (User.IsInRole("Administrador"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Crear Nuevo</a>
    </p>
}

<form asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label class="form-label">Nombre</label>
        <input type="text" name="nombre" value="@ViewBag.FiltroNombre" class="form-control" placeholder="Buscar por nombre..." />
    </div>
    <div class="col-auto">
        <label class="form-label">Estado</label>
        <select name="estado" class="form-control" asp-items="ViewBag.FiltroEstado">
            <option value="">-- Todos --</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Buscar</button>
        <a asp-action="Index" class="btn btn-link">Limpiar</a>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Descripcion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Estado)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EstaDisponible)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nombre)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Descripcion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Estado)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EstaDisponible)
            </td>
            <td>
                @Html.ActionLink("Detalles", "Details", new { id = item.Id })
                @if (User.IsInRole("Administrador"))
                {
                    <text> | </text>
                    @Html.ActionLink("Editar", "Edit", new { id = item.Id })
                    <text> | </text>
                    @Html.ActionLink("Borrar", "Delete", new { id = item.Id })
                }
            </td>
        </tr>
}
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted">No hay materiales que coincidan con la búsqueda.</p>
}
