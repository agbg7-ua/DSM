@model IEnumerable<WebMarkerSpace.Models.MaterialViewModel>
@using ApplicationCore.Domain.Enums

@{
    ViewData["Title"] = "Materiales";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Materiales</h1>
    @if (User.IsInRole("Administrador"))
    {
        <a asp-action="Create" class="btn btn-primary">+ Nuevo material</a>
    }
</div>

<form asp-action="Index"
      method="get"
      class="row g-2 align-items-end mb-4"
      id="form-filtro-materiales">

    <div class="col-auto">
        <label class="form-label">Nombre</label>
        <input type="text"
               name="nombre"
               value="@ViewBag.FiltroNombre"
               class="form-control"
               placeholder="Buscar por nombre..."
               autocomplete="off" />
    </div>

    <div class="col-auto">
        <label class="form-label">Categoría</label>
        <select name="categoria"
                class="form-control"
                asp-items="ViewBag.FiltroCategoria">
            <option value="">-- Todas --</option>
        </select>
    </div>

    <div class="col-auto">
        <label class="form-label">Estado</label>
        <select name="estado"
                class="form-control"
                asp-items="ViewBag.FiltroEstado">
            <option value="">-- Todos --</option>
        </select>
    </div>

    <div class="col-auto">
        <a asp-action="Index"
           class="btn btn-link"
           id="link-limpiar-filtro">
            Limpiar
        </a>

        <span id="spinner-materiales"
              class="spinner-border spinner-border-sm text-secondary ms-2 d-none"
              role="status"
              aria-hidden="true">
        </span>
    </div>
</form>

<form id="af-token-form" class="d-none">
    @Html.AntiForgeryToken()
</form>

<div id="materiales-resultados" aria-live="polite">
    @await Html.PartialAsync("_MaterialListPartial", Model)
</div>

@section Scripts
{
    <script src="~/js/material-index.js" asp-append-version="true"></script>
}
