@model WebMarkerSpace.Models.MaterialViewModel
@using ApplicationCore.Domain.Enums

@{
    ViewData["Title"] = Model.Nombre;
    bool disponible = Model.Estado == EstadoMaterial.Disponible;

    string badgeClass = Model.Estado switch {
        EstadoMaterial.Disponible      => "bg-success",
        EstadoMaterial.Prestado        => "bg-primary",
        EstadoMaterial.EnMantenimiento => "bg-warning text-dark",
        EstadoMaterial.Roto            => "bg-danger",
        _                              => "bg-secondary"
    };
}

<nav aria-label="@Localizer["Common.BreadcrumbLabel"]" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Material" asp-action="Index">@Localizer["Material.Index.Title"]</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Nombre</li>
    </ol>
</nav>

<div class="row g-4 align-items-start">

    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div style="height:320px; background:#f8f9fa; border-radius:0.375rem;"
                 class="d-flex align-items-center justify-content-center p-3">
                @if (!string.IsNullOrEmpty(Model.Imagen))
                {
                    <img src="@Model.Imagen" alt="@Model.Nombre"
                         style="max-width:100%; max-height:100%; object-fit:contain;" />
                }
                else
                {
                    <div class="text-center text-muted">
                        <i class="bi bi-image" style="font-size:3rem;"></i>
                        <p class="mt-2 small">@Localizer["Material.Details.NoImage"]</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <h1 class="mb-2">@Model.Nombre</h1>

        <div class="d-flex gap-2 mb-3 flex-wrap">
            <span class="badge bg-secondary fs-6">@Localizer.Localize(Model.Categoria)</span>
            <span class="badge @badgeClass fs-6">@Localizer.Localize(Model.Estado)</span>
        </div>

        @if (Model.Estado == EstadoMaterial.Prestado && !string.IsNullOrEmpty(Model.NombreUsuarioAsignado))
        {
            <div class="alert alert-info py-2 mb-3">
                <i class="bi bi-person me-1"></i> @Localizer["Material.Details.LoanedTo", Model.NombreUsuarioAsignado]
            </div>
        }

        <p class="text-muted mb-4" style="font-size:1.05rem;">@Model.Descripcion</p>

        <hr />

        <div class="d-flex gap-2 flex-wrap mt-3">
            @if (User.Identity != null && User.Identity.IsAuthenticated && disponible)
            {
                <a asp-controller="Prestamo" asp-action="Create" asp-route-materialId="@Model.Id"
                   class="btn btn-success btn-lg">
                    <i class="bi bi-clipboard-plus me-2"></i>@Localizer["Material.Details.RequestLoan"]
                </a>
            }
            else if (User.Identity == null || !User.Identity.IsAuthenticated)
            {
                <a asp-controller="Usuario" asp-action="Login" class="btn btn-primary btn-lg">
                    <i class="bi bi-box-arrow-in-right me-2"></i>@Localizer["Material.Details.LoginToRequest"]
                </a>
            }
            else if (!disponible)
            {
                <button class="btn btn-secondary btn-lg" disabled>
                    <i class="bi bi-x-circle me-2"></i>@Localizer["Material.Details.NotAvailable"]
                </button>
            }

            @if (User.IsInRole("Administrador"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                    <i class="bi bi-pencil me-1"></i>@Localizer["Common.Edit"]
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-1"></i>@Localizer["Material.Details.DeleteButton"]
                </a>
            }
        </div>

        <div class="mt-3">
            <a asp-action="Index" class="text-muted small">
                <i class="bi bi-arrow-left me-1"></i>@Localizer["Material.Details.BackToCatalog"]
            </a>
        </div>
    </div>

</div>
