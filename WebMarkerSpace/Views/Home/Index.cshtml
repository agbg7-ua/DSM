@model IEnumerable<ApplicationCore.Domain.EN.Material>
@using ApplicationCore.Domain.Enums

@{
    ViewData["Title"] = "Inicio";
}

<!-- HERO -->
<div class="text-white text-center py-5 mb-5 rounded-3" style="background-color:#2C3E50;">
    <div class="py-2 px-3">
        <h1 class="display-4 fw-bold mb-3">WebMarkerSpace</h1>
        <p class="lead mx-auto mb-4" style="max-width:560px;">
            Accede a herramientas, componentes y equipos del makerspace.
            Solicita lo que necesitas y ponlo en marcha.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Material" asp-action="Index" class="btn btn-success btn-lg">
                <i class="bi bi-grid me-2"></i>Ver catálogo
            </a>
            @if (User.Identity == null || !User.Identity.IsAuthenticated)
            {
                <a asp-controller="Usuario" asp-action="Register" class="btn btn-outline-light btn-lg">
                    <i class="bi bi-person-plus me-2"></i>Crear cuenta
                </a>
            }
            else
            {
                <a asp-controller="Prestamo" asp-action="Index" class="btn btn-outline-light btn-lg">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Mis préstamos
                </a>
            }
        </div>
    </div>
</div>

<!-- CÓMO FUNCIONA -->
<div class="mb-5">
    <h2 class="text-center mb-4">¿Cómo funciona?</h2>
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="p-4">
                <i class="bi bi-search mb-3 d-block" style="font-size:2.5rem; color:#18BC9C;"></i>
                <h5 class="fw-bold">1. Busca</h5>
                <p class="text-muted">Explora el catálogo de materiales disponibles. Filtra por categoría, nombre o estado.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4">
                <i class="bi bi-clipboard-plus mb-3 d-block" style="font-size:2.5rem; color:#18BC9C;"></i>
                <h5 class="fw-bold">2. Solicita</h5>
                <p class="text-muted">Inicia sesión y solicita el préstamo del material que necesitas para tu proyecto.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4">
                <i class="bi bi-tools mb-3 d-block" style="font-size:2.5rem; color:#18BC9C;"></i>
                <h5 class="fw-bold">3. Úsalo y devuélvelo</h5>
                <p class="text-muted">Recoge el material, completa tu proyecto y devuélvelo cuando termines.</p>
            </div>
        </div>
    </div>
</div>

<hr class="mb-5" />

<!-- NOVEDADES -->
@if (Model.Any())
{
    <div class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0">Últimas incorporaciones</h2>
            <a asp-controller="Material" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                Ver todo el catálogo <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100">
                        <div style="height:160px; overflow:hidden; background:#f8f9fa; border-radius:0.375rem 0.375rem 0 0;"
                             class="d-flex align-items-center justify-content-center p-2">
                            @if (!string.IsNullOrEmpty(item.Imagen))
                            {
                                <img src="@item.Imagen" alt="@item.Nombre"
                                     style="max-width:100%; max-height:100%; object-fit:contain;" />
                            }
                            else
                            {
                                <span class="text-muted small">Sin imagen</span>
                            }
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@item.Nombre</h5>
                            <p class="card-text text-muted small mb-3">@item.Descripcion</p>
                            @{
                                string badgeClass = item.Estado switch {
                                    EstadoMaterial.Disponible      => "bg-success",
                                    EstadoMaterial.Prestado        => "bg-primary",
                                    EstadoMaterial.EnMantenimiento => "bg-warning text-dark",
                                    EstadoMaterial.Roto            => "bg-danger",
                                    _                              => "bg-secondary"
                                };
                            }
                            <span class="badge bg-secondary me-1">@item.Categoria</span>
                            <span class="badge @badgeClass">@item.Estado</span>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a asp-controller="Material" asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary">Ver detalles</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
