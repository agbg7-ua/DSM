@model WebMarkerSpace.Models.RegistroUsuarioViewModel

@{
    ViewData["Title"] = "Registro";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
    bool oidcHabilitado = ViewBag.OidcHabilitado ?? false;
    string oidcNombre = ViewBag.OidcNombre ?? "proveedor externo";
    string? returnUrl = ViewBag.ReturnUrl;
}

<h1>Crea tu cuenta</h1>
<p class="lead">Regístrate para poder pedir materiales prestados.</p>
<hr />
<div class="row">
    <div class="col-md-5">

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" tabindex="-1"></div>
        }

        <form asp-action="Register" method="post" novalidate>
            <fieldset>
                <legend class="visually-hidden">Datos de la nueva cuenta</legend>

                <div class="form-group mb-3">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" autocomplete="name" aria-describedby="Nombre-error" required />
                    <span asp-validation-for="Nombre" class="text-danger" id="Nombre-error"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" autocomplete="email" inputmode="email" aria-describedby="Email-error" required />
                    <span asp-validation-for="Email" class="text-danger" id="Email-error"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Contrasenia" class="form-label"></label>
                    <input asp-for="Contrasenia" class="form-control" autocomplete="new-password" aria-describedby="Contrasenia-error" required />
                    <span asp-validation-for="Contrasenia" class="text-danger" id="Contrasenia-error"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="ConfirmarContrasenia" class="form-label"></label>
                    <input asp-for="ConfirmarContrasenia" class="form-control" autocomplete="new-password" aria-describedby="ConfirmarContrasenia-error" required />
                    <span asp-validation-for="ConfirmarContrasenia" class="text-danger" id="ConfirmarContrasenia-error"></span>
                </div>
            </fieldset>
            <div class="form-group mt-3">
                <button type="submit" class="btn btn-primary btn-accesible">Crear cuenta</button>
            </div>
        </form>

        @if (oidcHabilitado)
        {
            <div class="separador-o" role="separator" aria-label="o">
                <span>o</span>
            </div>
            <form asp-action="ExternalLogin" method="get">
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <button type="submit" class="btn btn-outline-secondary btn-accesible w-100">
                    Regístrate con @oidcNombre
                </button>
            </form>
            <p class="form-text mt-2">
                Si es la primera vez que entras con @oidcNombre, tu cuenta se creará automáticamente.
            </p>
        }

        <p class="mt-4">
            ¿Ya tienes cuenta? <a asp-action="Login">Inicia sesión</a>
        </p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
