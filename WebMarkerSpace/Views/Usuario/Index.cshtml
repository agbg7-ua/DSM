@model IEnumerable<WebMarkerSpace.Models.UsuarioViewModel>
@using ApplicationCore.Domain.Enums

@{
    ViewData["Title"] = Localizer["Usuario.Index.Title"];
}

<h1>@Localizer["Usuario.Index.Title"]</h1>

<form asp-action="Index"
      method="get"
      id="form-filtro-usuarios"
      class="row g-2 align-items-end mb-4">

    <div class="col-md-4">
        <label class="form-label">@Localizer["Usuario.Index.Search"]</label>

        <input type="text"
               class="form-control"
               name="texto"
               value="@ViewBag.FiltroTexto"
               placeholder="@Localizer["Usuario.Index.SearchPlaceholder"]" />
    </div>

    <div class="col-md-3">
        <label class="form-label">@Localizer["Common.Field.Role"]</label>

        <select name="rol"
                class="form-select"
                asp-items="ViewBag.FiltroRol">

            <option value="">@Localizer["Common.AllMasc"]</option>

        </select>
    </div>

    <div class="col-auto">

        <a asp-action="Index"
           class="btn btn-link"
           id="link-limpiar-filtro">

            @Localizer["Limpiar"]

        </a>

        <span id="spinner-usuarios"
              class="spinner-border spinner-border-sm text-secondary ms-2 d-none"
              role="status"
              aria-hidden="true">
        </span>

    </div>

</form>

<div id="usuarios-resultados">

    @await Html.PartialAsync("_UsuarioListPartial", Model)

</div>

<form id="af-token-form" class="d-none">
    @Html.AntiForgeryToken()
</form>

<div id="usuarios-i18n"
     class="d-none"
     data-confirmar-titulo="@Localizer["Usuario.Delete.ConfirmTitle"]"
     data-confirmar-texto="@Localizer["Usuario.Delete.ConfirmText"]"
     data-confirmar-boton="@Localizer["Usuario.Delete.ConfirmButton"]"
     data-cancelar="@Localizer["Cancelar"]"
     data-eliminado-titulo="@Localizer["Usuario.Delete.SuccessTitle"]"
     data-eliminado-texto="@Localizer["Usuario.Delete.SuccessText"]"
     data-error="@Localizer["Common.Error"]"
     data-error-borrar="@Localizer["Usuario.Delete.GenericError"]"
     data-error-red="@Localizer["Common.NetworkError"]">
</div>

@section Scripts
{
    <script src="~/js/usuario-index.js" asp-append-version="true"></script>
}
