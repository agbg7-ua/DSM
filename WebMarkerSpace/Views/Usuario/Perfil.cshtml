@model WebMarkerSpace.Models.PerfilViewModel

@{
    ViewData["Title"] = Localizer["Perfil.Title"];
}

<h1>@Localizer["Perfil.Title"]</h1>
<hr />

@if (TempData["MensajeExito"] != null)
{
    <div class="alert alert-success" role="status" aria-live="polite">@TempData["MensajeExito"]</div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" tabindex="-1"></div>
}

<div class="row">
    <div class="col-md-6">
        <form asp-action="Perfil" method="post" novalidate>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Rol" />

            <fieldset>
                <legend class="visually-hidden">@Localizer["Perfil.PersonalDataLegend"]</legend>
                <div class="form-group mb-3">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" autocomplete="name" aria-describedby="Nombre-error" required />
                    <span asp-validation-for="Nombre" class="text-danger" id="Nombre-error"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" autocomplete="email" inputmode="email" aria-describedby="Email-error" required />
                    <span asp-validation-for="Email" class="text-danger" id="Email-error"></span>
                </div>
                <div class="form-group mb-3">
                    <label for="rol-actual" class="form-label">@Localizer["Perfil.RoleLabel"]</label>
                    <input id="rol-actual" class="form-control" value="@Localizer.Localize(Model.Rol)" disabled aria-describedby="rol-ayuda" />
                    <div class="form-text" id="rol-ayuda">@Localizer["Perfil.RoleHelp"]</div>
                </div>
            </fieldset>

            <hr />
            <p class="text-muted" id="contrasenia-ayuda">@Localizer["Perfil.PasswordHelp"]</p>

            <fieldset aria-describedby="contrasenia-ayuda">
                <legend class="visually-hidden">@Localizer["Perfil.PasswordLegend"]</legend>
                <div class="form-group mb-3">
                    <label asp-for="NuevaContrasenia" class="form-label"></label>
                    <input asp-for="NuevaContrasenia" class="form-control" autocomplete="new-password" aria-describedby="NuevaContrasenia-error" />
                    <span asp-validation-for="NuevaContrasenia" class="text-danger" id="NuevaContrasenia-error"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="ConfirmarNuevaContrasenia" class="form-label"></label>
                    <input asp-for="ConfirmarNuevaContrasenia" class="form-control" autocomplete="new-password" aria-describedby="ConfirmarNuevaContrasenia-error" />
                    <span asp-validation-for="ConfirmarNuevaContrasenia" class="text-danger" id="ConfirmarNuevaContrasenia-error"></span>
                </div>
            </fieldset>

            <div class="form-group">
                <button type="submit" class="btn btn-primary btn-accesible">@Localizer["Perfil.SaveButton"]</button>
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Prestamo" asp-action="Index">@Localizer["Perfil.ViewLoans"]</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
