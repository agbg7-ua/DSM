@model WebMarkerSpace.Models.LoginUsuarioViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
    bool oidcHabilitado = ViewBag.OidcHabilitado ?? false;
    string oidcNombre = ViewBag.OidcNombre ?? "proveedor externo";
    string? returnUrl = ViewBag.ReturnUrl;
}

<h1>@Localizer["Login.Title"]</h1>
<p class="lead">@Localizer["Login.Lead"]</p>
<hr />
<div class="row">
    <div class="col-md-5">

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"
                 tabindex="-1" id="resumen-errores"></div>
        }

        <form asp-action="Login" method="post" novalidate>
            <fieldset>
                <legend class="visually-hidden">@Localizer["Login.FieldsetLegend"]</legend>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" autocomplete="email"
                           inputmode="email" aria-describedby="Email-error" required />
                    <span asp-validation-for="Email" class="text-danger" id="Email-error"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Contrasenia" class="form-label"></label>
                    <input asp-for="Contrasenia" class="form-control" autocomplete="current-password"
                           aria-describedby="Contrasenia-error" required />
                    <span asp-validation-for="Contrasenia" class="text-danger" id="Contrasenia-error"></span>
                </div>
            </fieldset>
            <div class="form-group">
                <button type="submit" class="btn btn-primary btn-accesible">@Localizer["Login.SubmitButton"]</button>
            </div>
        </form>

        @if (oidcHabilitado)
        {
            <div class="separador-o" role="separator" aria-label="@Localizer["Common.Or"]">
                <span>@Localizer["Common.Or"]</span>
            </div>
            <form asp-action="ExternalLogin" method="get">
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <button type="submit" class="btn btn-outline-secondary btn-accesible w-100">
                    @Localizer["Login.ExternalButton", oidcNombre]
                </button>
            </form>
        }

        <p class="mt-4">
            @Localizer["Login.NoAccount"] <a asp-action="Register">@Localizer["Login.RegisterHere"]</a>
        </p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
