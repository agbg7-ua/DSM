<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebMarkerSpace</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/flatly/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebMarkerSpace.styles.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#contenido-principal">Saltar al contenido principal</a>

    <div class="container">
        <main id="contenido-principal" role="main" class="pb-3" tabindex="-1">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted" aria-label="Pie de página">
        <div class="container">
            &copy; 2026 - WebMarkerSpace - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
