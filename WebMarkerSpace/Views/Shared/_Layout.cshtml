<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebMarkerSpace</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/flatly/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebMarkerSpace.styles.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#contenido-principal">Saltar al contenido principal</a>

    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction     = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary shadow-sm mb-3"
             aria-label="Navegación principal">
            <div class="container-fluid">

                <!-- Brand con icono -->
                <a class="navbar-brand d-flex align-items-center gap-2 fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-tools fs-5"></i>
                    WebMarkerSpace
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Mostrar u ocultar el menú de navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between" id="navbarSupportedContent">

                    <!-- Links principales -->
                    <ul class="navbar-nav flex-grow-1 gap-1">
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" ? "active fw-semibold" : "")"
                               asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house me-1"></i>Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Material" && currentAction != "Create" ? "active fw-semibold" : "")"
                               asp-area="" asp-controller="Material" asp-action="Index">
                                <i class="bi bi-grid me-1"></i>Materiales
                            </a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Prestamo" ? "active fw-semibold" : "")"
                                   asp-area="" asp-controller="Prestamo" asp-action="Index">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Préstamos
                                </a>
                            </li>
                            @if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(currentController == "Usuario" ? "active fw-semibold" : "")"
                                       asp-area="" asp-controller="Usuario" asp-action="Index">
                                        <i class="bi bi-people me-1"></i>Usuarios
                                    </a>
                                </li>
                                <li class="nav-item ms-1">
                                    <a class="btn btn-success btn-sm d-flex align-items-center"
                                       asp-area="" asp-controller="Material" asp-action="Create">
                                        <i class="bi bi-plus-lg me-1"></i>Nuevo material
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <!-- Zona usuario -->
                    <ul class="navbar-nav align-items-sm-center gap-1">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center me-1">
                                <span class="navbar-text opacity-75 small">
                                    <i class="bi bi-person-circle me-1"></i>
                                    <strong>@User.Identity.Name</strong>
                                    <span class="badge bg-secondary ms-1 fw-normal">
                                        @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                    </span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Usuario" && currentAction == "Perfil" ? "active fw-semibold" : "")"
                                   asp-controller="Usuario" asp-action="Perfil">
                                    <i class="bi bi-gear me-1"></i>Mi perfil
                                </a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Usuario" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-light btn-sm">
                                        <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm d-flex align-items-center"
                                   asp-controller="Usuario" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Entrar
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main id="contenido-principal" role="main" class="pb-3" tabindex="-1">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto py-3" aria-label="Pie de página">
        <div class="container">
            &copy; 2026 - WebMarkerSpace - <a asp-area="" asp-controller="Home" asp-action="Privacy">Política de privacidad</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
