@model IEnumerable<WebMarkerSpace.Models.PrestamoViewModel>

@{
    ViewData["Title"] = "Préstamos";
    bool esAdmin = (bool)(ViewBag.EsAdmin ?? false);
}

<h1>@(esAdmin ? "Préstamos" : "Mis préstamos")</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Nuevo préstamo</a>
</p>

<form asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label class="form-label">Estado</label>
        <select name="estado" class="form-control" asp-items="ViewBag.FiltroEstado">
            <option value="">-- Todos --</option>
        </select>
    </div>
    @if (esAdmin)
    {
        <div class="col-auto">
            <label class="form-label">Usuario</label>
            <select name="usuarioId" class="form-control" asp-items="ViewBag.FiltroUsuarioId">
                <option value="">-- Todos --</option>
            </select>
        </div>
    }
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Filtrar</button>
        <a asp-action="Index" class="btn btn-link">Limpiar</a>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            @if (esAdmin)
            {
                <th>
                    @Html.DisplayNameFor(model => model.NombreUsuario)
                </th>
            }
            <th>
                @Html.DisplayNameFor(model => model.FechaCreacion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Estado)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TotalDias)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Id)
            </td>
            @if (esAdmin)
            {
                <td>
                    @Html.DisplayFor(modelItem => item.NombreUsuario)
                </td>
            }
            <td>
                @Html.DisplayFor(modelItem => item.FechaCreacion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Estado)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TotalDias)
            </td>
            <td>
                @Html.ActionLink("Detalles", "Details", new { id = item.Id })
                @if (esAdmin)
                {
                    <text> | </text>
                    @Html.ActionLink("Editar", "Edit", new { id = item.Id })
                    <text> | </text>
                    @Html.ActionLink("Borrar", "Delete", new { id = item.Id })
                }
            </td>
        </tr>
}
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted">No hay préstamos que coincidan con el filtro.</p>
}
