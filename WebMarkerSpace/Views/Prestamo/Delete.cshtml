@using Microsoft.Extensions.Localization
@model WebMarkerSpace.Models.PrestamoViewModel

@{
    ViewData["Title"] = Localizer["EliminarPrestamo"];
}

<h1>@Localizer["Eliminar"]</h1>

<h3>@Localizer["ConfirmarEliminarPrestamo"]</h3>

<div>
    <h4>@Localizer["Prestamo"] #@Model.Id</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.NombreUsuario)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.NombreUsuario)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FechaCreacion)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FechaCreacion)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Estado)
        </dt>
        <dd class="col-sm-10">
            @Localizer.Localize(Model.Estado)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.TotalDias)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TotalDias)
        </dd>
    </dl>

    @if (Model.Lineas.Count > 0)
    {
        <p class="text-danger">
            @string.Format(Localizer["PrestamoConMateriales"], Model.Lineas.Count)
        </p>
    }

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        <input type="submit"
               value="@Localizer["Eliminar"]"
               class="btn btn-danger" />
        |
        <a asp-action="Index">@Localizer["Cancelar"]</a>
    </form>
</div>
